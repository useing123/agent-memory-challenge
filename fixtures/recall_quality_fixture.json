{
  "source": "Manual recall quality fixture",
  "total_tests": 2,
  "tests": [
    {
      "fixture_id": "contradiction-test-1",
      "description": "Tests if the memory service correctly handles direct fact evolution (contradiction).",
      "turns": [
        {
          "session_id": "contradiction-session-1",
          "user_id": "user-contradiction-1",
          "messages": [{"role": "user", "content": "I work at Stripe as an engineer."}],
          "timestamp": "2025-01-10T10:00:00Z"
        },
        {
          "session_id": "contradiction-session-2",
          "user_id": "user-contradiction-1",
          "messages": [{"role": "user", "content": "I just started a new role at Notion as a Product Manager."}],
          "timestamp": "2025-03-15T12:00:00Z"
        }
      ],
      "recall_query": {
        "query": "Where does this user work?",
        "expected_context_contains": ["Notion", "Product Manager"],
        "expected_context_not_contains": ["Stripe"]
      }
    },
    {
      "fixture_id": "multihop-test-1",
      "description": "Tests if the service can connect two separate facts to answer a multi-hop question.",
      "turns": [
        {
          "session_id": "multihop-session-1",
          "user_id": "user-multihop-1",
          "messages": [{"role": "user", "content": "My dog's name is Biscuit. He's a golden retriever."}],
          "timestamp": "2025-02-01T14:00:00Z"
        },
        {
          "session_id": "multihop-session-2",
          "user_id": "user-multihop-1",
          "messages": [{"role": "user", "content": "I'm thinking of moving from San Francisco to Seattle."}],
          "timestamp": "2025-04-05T18:00:00Z"
        }
      ],
      "recall_query": {
        "query": "What city does the user with the dog named Biscuit live in?",
        "expected_context_contains": ["San Francisco"],
        "expected_context_not_contains": []
      }
    }
  ]
}
